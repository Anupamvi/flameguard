# FlameGuard Environment Configuration

# ── LLM Provider ─────────────────────────────────────────────
# Choose: "anthropic" (direct API) or "azure" (Azure AI Foundry)
LLM_PROVIDER=anthropic

# ── Option A: Direct Anthropic API ───────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Option B: Azure AI Foundry ───────────────────────────────
# Set LLM_PROVIDER=azure and configure these:
# AZURE_ENDPOINT=https://<your-resource>.services.ai.azure.com
# AZURE_API_KEY=your-azure-api-key
# AZURE_API_VERSION=2024-06-01
#
# For keyless auth (Entra ID / Managed Identity), leave AZURE_API_KEY
# empty and install azure-identity: pip install azure-identity

# ── Common Settings ──────────────────────────────────────────
# Claude model to use (same model name works for both providers)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Database path (SQLite)
FLAMEGUARD_DB_PATH=./data/flameguard.db

# CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Upload limits
UPLOAD_MAX_SIZE_MB=50
