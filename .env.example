# FlameGuard Environment Configuration

# ── LLM Provider ─────────────────────────────────────────────
# Choose: "openai" (direct OpenAI API) or "azure" (Azure AI Foundry)
LLM_PROVIDER=azure

# ── Option A: Direct OpenAI API ──────────────────────────────
# Get your key at https://platform.openai.com/
# OPENAI_API_KEY=sk-your-key-here

# ── Option B: Azure AI Foundry ───────────────────────────────
# Set LLM_PROVIDER=azure and configure these:
AZURE_ENDPOINT=https://<your-resource>.services.ai.azure.com
AZURE_API_KEY=your-azure-api-key
AZURE_API_VERSION=2024-12-01-preview

# ── Common Settings ──────────────────────────────────────────
# Model deployment name
LLM_MODEL=gpt-5.4-nano

# Database path (SQLite)
FLAMEGUARD_DB_PATH=./data/flameguard.db

# CORS origins (JSON array)
CORS_ORIGINS=["http://localhost:3000"]

# Upload limits
UPLOAD_MAX_SIZE_MB=50
